<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml - 应用清单文件
    定义应用的基本信息、权限、组件（Activity、Service、Provider）
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 权限声明 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="屏幕翻译"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ScreenTranslate"
        android:usesCleartextTraffic="true">

        <!-- 主界面 Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ScreenTranslate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 设置界面 Activity -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- 日志查看界面 Activity -->
        <activity
            android:name=".ui.LogActivity"
            android:exported="false"
            android:theme="@style/Theme.ScreenTranslate" />

        <!-- OCR 测试文本 Activity -->
        <activity
            android:name=".ui.TestActivity"
            android:exported="false"
            android:theme="@style/Theme.ScreenTranslate" />

        <!-- FileProvider：安全地分享日志文件 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 无障碍服务：屏幕翻译的核心 -->
        <service
            android:name=".service.TranslateAccessibilityService"
            android:exported="true"
            android:foregroundServiceType="specialUse|mediaProjection"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 后台保活服务：App 打开即运行，防止进程被杀 -->
        <service
            android:name=".service.KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

    </application>
</manifest>
